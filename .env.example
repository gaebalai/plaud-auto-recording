# 인증 방식: password (기본) 또는 session (구글 간편로그인)
# - password: 아래 PLAUD_EMAIL/PLAUD_PASSWORD로 자동 로그인
# - session : ~/.plaud-pipeline-profile/ 에 저장된 브라우저 세션 재사용
#             (먼저 `node ./.claude/skills/plaud-pipeline/scripts/plaud_session_login.js --first-time`
#              로 GUI에서 한 번 구글 로그인 필요)
PLAUD_AUTH_MODE=password

# password 모드일 때만 필요
PLAUD_EMAIL=your@email.com
PLAUD_PASSWORD=your-password

# session 모드 프로필 위치 (선택, 기본: ~/.plaud-pipeline-profile)
# PLAUD_PROFILE_DIR=

# 다운로드 후 옮길 Plaud Web 폴더 ID (선택, 중복 다운로드 방지용)
# Plaud Web에서 폴더 클릭 후 URL의 tagId= 뒤 값
# 예: https://web.plaud.ai/file-list?tagId=a6fd8e0b3d95186c2dc6841e76913e2c
PLAUD_MOVE_TO_FOLDER_ID=

# API base (선택). 한국 사용자는 보통 기본값으로 OK.
# 연결이 안 되면 https://api.plaud.ai 시도.
# PLAUD_API_BASE=https://api-apne1.plaud.ai

# Playwright headless 모드 (cron 자동화 시 1로 설정)
# PLAUD_HEADLESS=1

# Whisper 동작 조정 (선택)
# WHISPER_MODEL=large-v3-turbo   # medium / small 로 줄이면 빠름
# WHISPER_DEVICE=cpu             # macOS에서는 cpu 고정 (faster-whisper는 mps 미지원)
# WHISPER_COMPUTE_TYPE=int8

# 알림/유지 옵션 (선택)
# PLAUD_NOTIFY_ON_SUCCESS=0      # 1로 두면 성공 시에도 macOS 알림. 기본은 실패만 알림
# PLAUD_LOG_RETENTION_DAYS=30    # 이 일수 이상 된 logs/plaud_*.log 자동 삭제 (0이면 비활성)

# 경로 override (선택)
# PLAUD_INPUT_DIR=
# PLAUD_PROCESSED_DIR=
# PLAUD_OUTPUT_DIR=
